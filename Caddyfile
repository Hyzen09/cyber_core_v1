# Listen on standard HTTP (Port 80) for any incoming IP address
:80 {
    # 1. Backend Routes (FastAPI)
    handle /api/upload-pdf* {
        reverse_proxy backend:8000
    }

    handle /api/agents* {
        reverse_proxy backend:8000
    }

    # 2. Frontend Routes (Next.js)
    handle {
        reverse_proxy frontend:3000
    }
}