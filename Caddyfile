cyber-studio.duckdns.org {
    # 1. Heavy-Lifting Routes -> Python Backend (FastAPI)
    handle /api/* {
        reverse_proxy cyber_core_backend:8000
    }

    # 2. UI & Chat Streaming -> Next.js Frontend
    handle {
        reverse_proxy cyber_core_frontend:3000 {
            # This is the magic command for LangChain!
            # It tells Caddy NOT to buffer the AI's response, 
            # allowing Next.js to stream text word-by-word instantly.
            flush_interval -1
        }
    }
}